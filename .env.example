# ─────────────────────────────────────────
#  VARIABLES DE ENTORNO - COTIZADOR BOT
# ─────────────────────────────────────────

# ── Bot de cotizaciones ───────────────────
# Token del bot de Telegram (habla con @BotFather)
TELEGRAM_BOT_TOKEN=tu_token_aqui

# ── Bot de notas de pago ──────────────────
# Token del segundo bot de Telegram (crea otro bot en @BotFather)
TELEGRAM_NOTAS_TOKEN=tu_token_notas_aqui

# ── Anthropic (Claude) ────────────────────
# Obtenla en https://console.anthropic.com
ANTHROPIC_API_KEY=tu_api_key_aqui

# ── Notion ────────────────────────────────
# 1. Crea una Integration en https://www.notion.so/my-integrations
# 2. Copia el "Internal Integration Secret"
NOTION_TOKEN=secret_xxxxxxxxxxxx

# ID de la base de datos de Notion para NOTAS DE PAGO
# Se encuentra en la URL: https://notion.so/tu-workspace/[ESTE-ES-EL-ID]?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la base de datos de Notion para COTIZACIONES
NOTION_COTIZACIONES_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── HTTP Server (export-pdf) ──────────────
# URL del frontend React (para CORS). Usa * para desarrollo local.
FRONTEND_URL=http://localhost:5173

# Límite de tamaño del body JSON en MB (default 400)
MAX_PAYLOAD_MB=400

# Memoria máxima de Node.js (recomendado en Railway para cargas grandes)
NODE_OPTIONS=--max-old-space-size=2048

PORT=3000